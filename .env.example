# Copy to .env and fill in. Never commit .env.

# === Claude ===
ANTHROPIC_API_KEY=sk-ant-...

# === Topstep via ProjectX Gateway ===
# ProjectX supports TWO auth flows; use whichever your dashboard requires.
# Set PROJECTX_AUTH_MODE to force a specific mode, or leave blank for
# auto-detect (picks APP if appId+verifyKey present, else KEY).
PROJECTX_AUTH_MODE=              # key | app | (blank = auto)

# --- Flow A: simple API-key (older / simpler) ---
PROJECTX_API_KEY=
PROJECTX_USERNAME=

# --- Flow B: application auth (required for some accounts; stricter) ---
# Dashboard will show these as "application credentials" or similar
# PROJECTX_USERNAME    (same var as above)
PROJECTX_PASSWORD=
PROJECTX_DEVICE_ID=              # typically a UUID you generate once
PROJECTX_APP_ID=
PROJECTX_VERIFY_KEY=

# --- Common ---
PROJECTX_ACCOUNT_ID=             # your Combine account numeric id
PROJECTX_ENV=demo                # demo | live
PROJECTX_BASE_URL=               # blank = https://api.topstepx.com (default)

# === Market data (pick one or more) ===
POLYGON_API_KEY=
DATABENTO_API_KEY=
CME_DATAMINE_KEY=

# === Fundamental data (all free; register once) ===
# FRED — macro series (rates, CPI, DXY). Works without a key (rate-limited).
# Free signup: https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=

# EIA — petroleum + nat gas inventories. REQUIRED key.
# Free signup: https://www.eia.gov/opendata/register.php
EIA_API_KEY=

# USDA NASS — crop progress, cattle-on-feed, grain stocks. REQUIRED key.
# Free signup: https://quickstats.nass.usda.gov/api
USDA_NASS_KEY=

# CFTC Commitments of Traders — no key needed (public CSVs via Socrata)

# === News / web ===
# Optional paid news APIs (agents prefer these when set, else fall back to RSS)
NEWSAPI_KEY=
BENZINGA_API_KEY=
TAVILY_API_KEY=   # for agent web search
DJ_NEWSWIRES_KEY= # Dow Jones Newswires (enterprise WSJ content feed)

# === X / Twitter ===
# Official API bearer token. Basic tier (~$100/mo) is sufficient for
# agent-scale polling. Get from developer.x.com.
X_BEARER_TOKEN=

# === Operational ===
FUND_MODE=paper       # paper | live — real orders only when live
LOG_LEVEL=INFO
DB_PATH=./state/fund.db
VAULT_PATH=./vault
